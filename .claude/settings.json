{
  "permissions": {
    "allow": [
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(ls:*)",
      "Bash(node --check:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(sed -n:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(diff:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(git -C \"z:\\\\Documents\\\\Nextcloud\\\\Finanzwesir 2.0\\\\Theme\" ls-files:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.peakhour.io)",
      "WebFetch(domain:docs.google.com)",
      "WebFetch(domain:www.jefftk.com)",
      "WebFetch(domain:www.jsdelivr.com)",
      "WebFetch(domain:rolldown.rs)",
      "WebFetch(domain:yuiblog.com)",
      "WebFetch(domain:engineering.fb.com)",
      "WebFetch(domain:docs.ghost.org)",
      "WebFetch(domain:ghost.org)",
      "WebFetch(domain:aspirethemes.com)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(curl:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NoProfile -File \".claude\\hooks\\check-protected-paths.ps1\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NoProfile -File \".claude\\hooks\\session-start.ps1\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -NoProfile -File \".claude\\hooks\\notify.ps1\" -Title \"Claude fertig\" -Message \"Task abgeschlossen\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -NoProfile -File \".claude\\hooks\\notify.ps1\" -Title \"Claude braucht dich\" -Message \"Freigabe erforderlich\""
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  }
}