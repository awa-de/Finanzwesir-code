<nav class="flex items-center justify-between gap-4 border-t border-border pt-6 text-sm" aria-label="Seitennavigation">
    {{#if prev}}
        <a class="font-semibold text-primary no-underline hover:text-petrol" href="{{page_url prev}}">← Neuere Beiträge</a>
    {{/if}}

    <span class="text-text-muted">Seite {{page}} von {{pages}}</span>

    {{#if next}}
        <a class="font-semibold text-primary no-underline hover:text-petrol" href="{{page_url next}}">Ältere Beiträge →</a>
    {{/if}}
</nav>
