<footer class="mt-12 border-t border-border bg-bg-faint">
    <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-8 text-sm text-text-muted sm:px-6 lg:px-8">
        <nav class="flex flex-wrap gap-x-4 gap-y-2" aria-label="Rechtliches">
            <a class="font-semibold text-text-sec no-underline hover:text-primary" href="/impressum">Impressum &amp; Kontakt</a>
            <a class="font-semibold text-text-sec no-underline hover:text-primary" href="/datenschutz">Datenschutz</a>
        </nav>

        {{#if @site.secondary_navigation}}
            <nav class="[&_a]:font-semibold [&_a]:text-text-sec [&_a]:no-underline [&_a:hover]:text-primary [&_ul]:flex [&_ul]:flex-wrap [&_ul]:gap-x-4 [&_ul]:gap-y-2" aria-label="Weitere Navigation">
                {{navigation type="secondary"}}
            </nav>
        {{/if}}

        <div class="flex flex-wrap gap-x-4 gap-y-2">
            {{#if @site.twitter}}
                <a class="font-semibold text-text-sec no-underline hover:text-primary" href="{{social_url type="twitter"}}" rel="me">Twitter</a>
            {{/if}}
            {{#if @site.facebook}}
                <a class="font-semibold text-text-sec no-underline hover:text-primary" href="{{social_url type="facebook"}}" rel="me">Facebook</a>
            {{/if}}
        </div>

        <p class="text-text-muted">&copy; {{@site.title}}</p>
    </div>
</footer>
