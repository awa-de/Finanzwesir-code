{{!< default}}

{{#post}}
    <article class="{{post_class}} fw-page">
        <header class="fw-page__header">
            <h1>{{title}}</h1>
        </header>

        {{#if feature_image}}
            <figure class="fw-page__feature-image">
                <img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
            </figure>
        {{/if}}

        <section class="gh-content">
            {{content}}
        </section>
    </article>
{{/post}}
