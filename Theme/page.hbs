{{!< default}}

{{#post}}
    <article class="{{post_class}} mx-auto max-w-2xl">
        <header class="mb-8 border-b border-border pb-6 sm:mb-12 sm:pb-8">
            <h1 class="font-display text-3xl leading-tight text-primary sm:text-4xl">{{title}}</h1>
        </header>

        <section class="gh-content">
            {{content}}
        </section>
    </article>

    <script defer src="{{asset "js/vendor/chart.umd.min.js"}}"></script>
    <script type="module" src="{{asset "js/fw-chart-engine/index.js"}}"></script>
{{/post}}
