{{!< default}}

{{#post}}
    {{#has tag="#seo-noindex"}}
        {{#has tag="#seo-nosnippet"}}
            {{#contentFor "head"}}
    <meta name="robots" content="noindex, nosnippet">
            {{/contentFor}}
        {{else}}
            {{#contentFor "head"}}
    <meta name="robots" content="noindex">
            {{/contentFor}}
        {{/has}}
    {{else}}
        {{#has tag="#seo-nosnippet"}}
            {{#contentFor "head"}}
    <meta name="robots" content="nosnippet">
            {{/contentFor}}
        {{/has}}
    {{/has}}

    {{#has tag="#schema-article"}}
        {{#contentFor "head"}}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": {{json title}},
        "url": "{{url absolute="true"}}",
        "mainEntityOfPage": "{{url absolute="true"}}",
        "datePublished": "{{date format="YYYY-MM-DD"}}",
        "dateModified": "{{date updated_at format="YYYY-MM-DD"}}",
        "inLanguage": {{json @site.locale}},
        "publisher": {
            "@type": "Organization",
            "name": {{json @site.title}},
            "url": {{json @site.url}}{{#if @site.logo}},
            "logo": {{json @site.logo}}{{/if}}
        }{{#if meta_description}},
        "description": {{json meta_description}}{{else}}{{#if custom_excerpt}},
        "description": {{json custom_excerpt}}{{/if}}{{/if}}{{#if feature_image}},
        "image": {{json feature_image}}{{/if}}{{#if primary_author}},
        "author": {
            "@type": "Person",
            "name": {{json primary_author.name}}
        }{{/if}}
    }
    </script>
        {{/contentFor}}
    {{else}}
    {{#has tag="#schema-about"}}
        {{#contentFor "head"}}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "AboutPage",
