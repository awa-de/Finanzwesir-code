{
  "name": "finanzwesir",
  "description": "Custom Ghost theme for Finanzwesir with integrated chart engine",
  "version": "1.0.0",
  "license": "MIT",
  "author": {
    "name": "Finanzwesir"
  },
  "engines": {
    "ghost": ">=6.0.0"
  },
  "keywords": [
    "ghost-theme",
    "finance",
    "charts"
  ],
  "config": {
    "posts_per_page": 10,
    "image_sizes": {
      "xxs": { "width": 30 },
      "xs": { "width": 100 },
      "s": { "width": 300 },
      "m": { "width": 600 },
      "l": { "width": 1000 },
      "xl": { "width": 2000 }
    },
    "card_assets": true
  }
}
